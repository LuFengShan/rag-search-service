#================================================================
# RAG知识库智能问答系统 - 环境变量配置
# 复制此文件为 .env 并修改配置
#================================================================

# 数据库配置
POSTGRES_DB=example_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your-64-character-secret-key-here-must-be-at-least-64-characters
JWT_EXPIRATION=86400000

# DeepSeek AI 配置（Chat）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 阿里云百炼 Embedding 配置
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# 应用配置
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# JVM配置
JAVA_OPTS=-Xms512m -Xmx1024m

# 文件上传配置
MAX_FILE_SIZE=50MB

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=./logs
